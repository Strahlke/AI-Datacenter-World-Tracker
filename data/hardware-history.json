  "quality_notes": [
    {
      "severity": "medium",
      "note_de": "Ein direkter 365-Tage-Geizhals-Backfill fuer 40 feste GPU-, CPU-, DRAM- und SSD-MPNs liegt nun separat vor. Weil er die heutige Wunschlisten-Zusammensetzung rueckwirkend rekonstruiert, bleibt der aktuelle CHPI bis zur Revisionskalibrierung ein vorlaeufiger Markt-Druckindex und kein vollstaendiger Retail-Preisindex.",
      "note_en": "A direct 365-day Geizhals backfill for 40 fixed GPU, CPU, DRAM and SSD MPNs is now available separately. Because it reconstructs today's wishlist composition retrospectively, the current CHPI remains a provisional market-pressure index rather than a complete retail price index until revision stability is calibrated."
    },
    {
      "severity": "medium",
      "note_de": "Die SEC-Capex-Reihe umfasst konzernweite PP&E-Ausgaben der vier Unternehmen. Sie ist breiter als AI-Rechenzentren und deckt nicht den gesamten Weltmarkt ab.",
      "note_en": "The SEC capex series covers company-wide PP&E spending by four companies. It is broader than AI data centers and does not cover the whole global market."
    },
    {
      "severity": "low",
      "note_de": "Der BLS-Wert fuer Oktober 2025 fehlt wegen des damaligen Ausfalls der US-Bundesfinanzierung. Nur fuer die abgeleitete Sechsmonatsrechnung wird zwischen September und November linear interpoliert.",
      "note_en": "The October 2025 BLS value is unavailable because of the U.S. federal funding lapse. It is linearly interpolated between September and November only for the derived six-month calculation."
    }
  ],
